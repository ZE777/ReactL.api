{
  "Logging": {
    "LogLevel": {
      // 預設 Log 等級，Information 以上才會輸出
      "Default": "Information",
      // ASP.NET Core 框架內部的 log 只顯示 Warning 以上，避免過多雜訊
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // 限制接受請求的 Host，* 表示接受任何 Host；生產環境可改為指定域名
  "AllowedHosts": "*",

  // ── 資料庫連線字串 ────────────────────────────────────────────────────────
  "ConnectionStrings": {
    // 密碼（敏感）此處留空、不進版控；本機開發於 appsettings.Development.json 覆蓋，生產環境透過環境變數覆蓋
    // TrustServerCertificate=True：本機開發時跳過 SSL 憑證驗證，生產環境需改為 False 並設置正式憑證
    "DefaultConnection": "Server=DESKTOP-J8V78KP\\SQLEXPRESS;Database=ReactL;User Id=sa;Password=;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },

  // ── AES 加密設定 ──────────────────────────────────────────────────────────
  "EncryptionSettings": {
    // Key 和 IV 均為高度敏感資訊，此處留空，必須透過 User Secrets 設定
    // Key 生成（PowerShell）：[Convert]::ToBase64String([System.Security.Cryptography.Aes]::Create().Key)
    // IV 生成（PowerShell）：[Convert]::ToBase64String([System.Security.Cryptography.Aes]::Create().IV)
    // dotnet user-secrets set "EncryptionSettings:Key" "<base64-32-bytes>"
    // dotnet user-secrets set "EncryptionSettings:Iv" "<base64-16-bytes>"
    "Key": "",
    "Iv": ""
  },

  // ── 應用程式基本設定 ──────────────────────────────────────────────────────
  "AppSettings": {
    // 應用程式對外的基礎 URL，用於 CORS、Webhook Callback、Email 連結
    // 生產環境改為 IIS 站台的實際網址，例如 https://api.yourdomain.com
    "BaseUrl": "https://localhost:7001",
    "AppName": "ReactL Prompt Studio"
  },

  // ── CORS 跨域設定 ─────────────────────────────────────────────────────────
  "CorsSettings": {
    // 允許跨域存取的前端來源清單
    // 生產環境在 appsettings.Production.json 補上 IIS 站台 URL
    "AllowedOrigins": [
      "http://localhost:3000", // Next.js 前台開發伺服器
      "http://localhost:5173", // Vite 後台管理開發伺服器
      "https://election-hangnail-reopen.ngrok-free.dev" // ngrok 對外發布（單一網址同源時 CORS 不觸發，仍加上最保險）
    ]
  },

  // ── JWT 認證設定 ──────────────────────────────────────────────────────────
  "JwtSettings": {
    // Token 發行者，驗證時確認 Token 來源是本系統
    "Issuer": "ReactL.api",
    // Token 受眾，確認 Token 是發給前端使用
    "Audience": "ReactL.web",
    // Token 有效期限（分鐘），60 分鐘後需重新登入
    "ExpirationMinutes": 60,
    // 簽名密鑰（敏感）：禁止在此設定，請使用 User Secrets
    // dotnet user-secrets set "JwtSettings:SecretKey" "your-256bit-secret"
    "SecretKey": ""
  },

  // ── 公開端點流量限制 ──────────────────────────────────────────────────────
  "RateLimitSettings": {
    // 公開聊天端點每個來源 IP 每分鐘允許的請求數，超過回 429
    "PublicPerMinute": 15,
    // 超過上限時的排隊數；0 = 立即拒絕不排隊
    "QueueLimit": 0,
    // 是否信任反向代理 X-Forwarded-For 取得真實 IP；IIS in-process 通常設 false，
    // 置於 Nginx/CDN/Cloudflare 後方才設 true（並建議於正式環境設定 KnownProxies）
    "UseForwardedHeaders": false
  },

  // ── 前台公開聊天（存取碼閘門與配額）──────────────────────────────────────
  "PublicChatSettings": {
    // 是否要求有效存取碼才能使用公開聊天；false 時任何人皆可（仍受流量限制）
    "RequireAccessCode": true,
    // 全站每日 token 預算護欄（系統金鑰），超過則公開聊天暫停；0 = 不限制
    "GlobalDailyTokenBudget": 0,
    // 後台新建存取碼的預設每日 token 上限
    "DefaultDailyTokenLimit": 50000
  },

  // ── 啟動種子 Admin（僅在尚無任何 Admin 時建立）────────────────────────────
  "AdminSeedSettings": {
    "Enabled": true,
    "Email": "admin@reactl.local",
    // 預設密碼（敏感）此處留空、不進版控；本機開發於 appsettings.Development.json 覆蓋，生產環境以環境變數覆蓋；首登後強制改密
    "DefaultPassword": "",
    "DisplayName": "管理員"
  },

  // ── AI API 串接設定 ───────────────────────────────────────────────────────
  "AiSettings": {
    // 預設模型，格式 "providerId:modelId"
    "DefaultModel": "groq:llama-3.3-70b-versatile",
    // 單次回應最大 Token 數，直接影響 API 費用，視需求調整
    "MaxTokens": 4096,
    // Discord 工具呼叫路徑的回應上限（較小，避免小模型 TPM 超限；Discord 訊息亦會截斷）
    "ToolCallMaxTokens": 2048,
    // 呼叫 AI API 的逾時秒數；AI 回應較慢，建議 60 秒以上
    "TimeoutSeconds": 60,
    // 呼叫失敗時的重試次數，僅針對 5xx 和網路逾時，4xx 不重試（避免重複計費）
    "MaxRetryCount": 3,
    // 各提供商 API 金鑰（敏感）：禁止在此設定，請使用 User Secrets
    // dotnet user-secrets set "AiSettings:ProviderKeys:groq" "gsk_..."
    "ProviderKeys": {},
    "Providers": [
      {
        "Id": "groq",
        "DisplayName": "Groq",
        "BaseUrl": "https://api.groq.com/openai/v1/",
        "SupportsStreamUsage": true,
        "Models": [
          { "Id": "llama-3.3-70b-versatile", "DisplayName": "Llama 3.3 70B" },
          { "Id": "llama-3.1-8b-instant", "DisplayName": "Llama 3.1 8B（快速）" },
          { "Id": "qwen/qwen3-32b", "DisplayName": "Qwen3 32B" }
        ]
      },
      {
        "Id": "mistral",
        "DisplayName": "Mistral",
        "BaseUrl": "https://api.mistral.ai/v1/",
        "SupportsStreamUsage": true,
        "Models": [
          { "Id": "mistral-small-latest", "DisplayName": "Mistral Small", "RecommendedForTools": true },
          { "Id": "mistral-large-latest", "DisplayName": "Mistral Large", "RecommendedForTools": true },
          { "Id": "open-mistral-7b", "DisplayName": "Mistral 7B（輕量）", "RecommendedForTools": true }
        ]
      },
      {
        "Id": "cerebras",
        "DisplayName": "Cerebras",
        "BaseUrl": "https://api.cerebras.ai/v1/",
        "Models": [
          { "Id": "gpt-oss-120b", "DisplayName": "GPT OSS 120B" },
          { "Id": "zai-glm-4.7", "DisplayName": "ZAI GLM 4.7", "RecommendedForTools": true }
        ]
      },
      {
        "Id": "sambanova",
        "DisplayName": "SambaNova",
        "BaseUrl": "https://api.sambanova.ai/v1/",
        "Models": [
          { "Id": "Meta-Llama-3.3-70B-Instruct", "DisplayName": "Llama 3.3 70B" },
          { "Id": "Llama-4-Maverick-17B-128E-Instruct", "DisplayName": "Llama 4 Maverick 17B" },
          { "Id": "DeepSeek-V3.1", "DisplayName": "DeepSeek V3.1" }
        ]
      }
    ]
  },

  // ── Discord 多步 agent 工具（依條件找人→執行動作）────────────────────────────
  // 讓 Discord Bot 能以自然語言「掃訊息找出符合條件的人 → 批次執行動作」。
  // 詳見 workflows/discord-agentic-tools-proposal.md
  "DiscordAgentSettings": {
    // 功能總開關；false 時 Discord 回到原本「單輪指定對象式」function calling（等同舊行為）
    "Enabled": true,
    // true=任何成員都能發起「掃描+提名單」（唯讀無害）；false=需具該動作權限才能發起
    "AllowAnyoneInitiate": true,
    // false（建議）=僅具該動作權限的管理員可調整勾選/按執行；true=任何人可按（⚠️ 僅測試，正式請保持 false）
    "AllowAnyoneConfirm": false,
    // 【單位：秒】一般成員「發起掃描」的冷卻時間，防止濫用洗 AI 額度/洗版
    "InitiateCooldownSeconds": 30,
    // 【單位：秒】管理員（具 Moderate Members / Administrator）的發起冷卻時間，通常較短
    "InitiateCooldownSecondsForAdmin": 10,
    // 【單位：分鐘】使用者沒指定時間時，預設往回掃多久。10080 = 7 天
    "DefaultScanWindowMinutes": 10080,
    // 【單位：分鐘】掃描時間窗硬上限；使用者要求超過此值會被擋並列出規則。需 ≥ 預設值。10080 = 7 天
    "MaxScanWindowMinutes": 10080,
    // 【單位：則】單次最多分析的訊息數（與時間窗誰先到算誰）。控成本/避開免費層 TPM 的主要護欄；
    // 注意：忙碌頻道下這個會先到，實際覆蓋時間可能遠短於時間窗
    "MaxScanMessages": 120,
    // 【單位：人】單次批次動作最多影響人數（對齊 Discord 多選上限 25）
    "MaxBatchTargets": 25,
    // 【單位：步】agent 迴圈最大步數（防止無限/暴衝）
    "MaxStepsPerCommand": 3,
    // 【單位：token】每道指令的 token 天花板（累計輸入+輸出，超過即停）
    "MaxTokensPerCommand": 30000,
    // 【單位：分鐘】待確認批次清單的暫存存活時間；超過未按執行即失效
    "PendingTtlMinutes": 5,
    // 掃描/判斷用的模型（"providerId:modelId"）；留空＝用該 Bot 設定的模型（預設）。
    // 填便宜模型（如 groq:llama-3.1-8b-instant）可省成本，但小模型工具呼叫較不穩
    "ScanModel": ""
  }

}
